# ==============================================================================
# RevOps IA SaaS — Variables d'environnement (dev local)
# Copier ce fichier en .env et renseigner les valeurs réelles.
# NE JAMAIS committer .env dans git.
# ==============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=revops_db
DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@localhost:5432/revops_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Backend FastAPI ────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
INTERNAL_SECRET=change_me_internal_secret
ORCHESTRATOR_URL=http://localhost:8001

# ── Orchestrateur Rust ─────────────────────────────────────────────────────────
INTER_SERVICE_SECRET=change_me_in_production
BACKEND_API_URL=http://localhost:8000
RAG_API_URL=http://localhost:8002
MCP_CRM_URL=http://localhost:9001
MCP_BILLING_URL=http://localhost:9002
MCP_ANALYTICS_URL=http://localhost:9003
MCP_SEQUENCES_URL=http://localhost:9004
MCP_FILESYSTEM_URL=http://localhost:9005
DEFAULT_MODEL=gpt-4o

# ── LLM API Keys (NE PAS committer) ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── MCP Servers ────────────────────────────────────────────────────────────────
INTERNAL_API_KEY=changeme-internal-api-key
# optionnel
REDIS_URL=redis://localhost:6379/0

# ── RAG Service ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
CHUNK_SIZE=512
CHUNK_OVERLAP=50
DEFAULT_TOP_K=5
STORAGE_BASE_PATH=/data/storage

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OpenTelemetry ──────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Logging ────────────────────────────────────────────────────────────────────
RUST_LOG=info
LOG_LEVEL=INFO
ENVIRONMENT=development
