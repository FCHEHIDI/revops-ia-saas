{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            COUNT(*)::bigint AS \"total: i64\",\n            SUM(amount) AS \"total_amount: Decimal\"\n        FROM invoices\n        WHERE tenant_id = $1\n            AND ($2::invoice_status IS NULL OR status = $2)\n            AND ($3::date IS NULL OR due_date >= $3)\n            AND ($4::date IS NULL OR due_date <= $4)\n        ",
  "describe": {
    "columns": [
      {
        "ordinal": 0,
        "name": "total: i64",
        "type_info": "Int8"
      },
      {
        "ordinal": 1,
