{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id, invoice_number,\n            status AS \"status: InvoiceStatus\",\n            amount, currency, due_date\n        FROM invoices\n        WHERE tenant_id = $1\n            AND ($2::invoice_status IS NULL OR status = $2)\n            AND ($3::date IS NULL OR due_date >= $3)\n            AND ($4::date IS NULL OR due_date <= $4)\n        ORDER BY created_at DESC\n        LIMIT $5 OFFSET $6\n        ",
