{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            status AS \"status: SubscriptionStatus\",\n            plan_name,\n            current_period_end,\n            trial_end,\n            seats,\n            features\n        FROM subscriptions\n        WHERE tenant_id = $1\n            AND status IN ('active', 'trialing', 'past_due')\n        ORDER BY created_at DESC\n        LIMIT 1\n        ",
