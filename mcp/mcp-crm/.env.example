# Required — URL of the internal FastAPI backend
BACKEND_URL=http://backend:8000

# Required — shared secret validated by verify_internal_key() in the backend
INTERNAL_API_KEY=your-secret-key-here

# Optional — server port (default: 9001)
PORT=9001

# Optional — log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Optional — httpx read timeout in seconds (default: 10.0)
HTTP_TIMEOUT=10.0
