{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id,\n            title,\n            category AS \"category: PlaybookCategory\",\n            description,\n            tags,\n            version\n        FROM fs_playbooks\n        WHERE tenant_id = $1\n          AND is_active = true\n          AND ($2::playbook_category IS NULL OR category = $2)\n          AND ($3::text[] IS NULL OR tags @> $3)\n        ORDER BY title ASC\n        LIMIT $4 OFFSET $5\n        ",
