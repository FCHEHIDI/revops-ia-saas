RUST_LOG=info
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# Secret partagé avec le Backend API pour l'authentification inter-service
INTER_SERVICE_SECRET=change_me_in_production

# URLs des services internes
BACKEND_API_URL=http://backend:8000
RAG_API_URL=http://rag:8002

# Serveurs MCP (ports exposés par docker-compose)
MCP_CRM_URL=http://mcp-crm:9001
MCP_BILLING_URL=http://mcp-billing:9002
MCP_ANALYTICS_URL=http://mcp-analytics:9003
MCP_SEQUENCES_URL=http://mcp-sequences:9004
MCP_FILESYSTEM_URL=http://mcp-filesystem:9005

# Redis (queue des jobs LLM)
REDIS_URL=redis://redis:6379

# LLM providers — au moins un doit être renseigné
# Modèle par défaut : préfixe "gpt-*" → OpenAI, "claude-*" → Anthropic
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=gpt-4o

# Observabilité (optionnel)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
