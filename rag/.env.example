ENVIRONMENT=development
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8002

# Inter-service authentication (shared with orchestrator and backend)
INTERNAL_API_KEY=change_me_in_production

# Qdrant vector store
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Embeddings (sentence-transformers)
# Model is downloaded from HuggingFace Hub on first startup
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=32

# Chunking strategy
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval defaults
DEFAULT_TOP_K=5
MIN_SCORE=0.0

# Redis ingestion queue
REDIS_URL=redis://redis:6379
INDEXING_QUEUE_NAME=rag:indexing

# Shared storage volume (must match mcp-filesystem volume mount)
STORAGE_BASE_PATH=/data/storage

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
